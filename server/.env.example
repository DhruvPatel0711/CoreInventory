# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/coreinventory

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_in_production
