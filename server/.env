# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/coreinventory

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=dev_secret_do_not_use_in_prod
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Email (NodeMailer) ───────────────────────────────
EMAIL_USER=
EMAIL_PASS=
